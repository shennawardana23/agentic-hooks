{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"This repo has a collaboration policy — see POLICY.md and CLAUDE.md before proceeding.\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/check-bash-env-dump.sh\""
          }
        ]
      }
    ]
  }
}
